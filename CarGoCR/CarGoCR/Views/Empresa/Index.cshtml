@model CarGoCR.Models.Empresa

@{
    ViewData["Title"] = "Empresa";
}
    <style>
            :root {
                --bg: #0f1117;
                --sidebar-bg: #13151e;
                --card-bg: #1a1d27;
                --card-border: #252836;
                --text-primary: #f0f2f8;
                --text-secondary: #7b8099;
                --text-muted: #4a5068;
                --accent-blue: #4f7cff;
                --accent-green: #34d399;
                --accent-red: #f87171;
                --accent-purple: #a78bfa;
                --hover-bg: #1f2235;
                --active-bg: #252a3d;
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                font-family: 'DM Sans',sans-serif;
                background: var(--bg);
                color: var(--text-primary);
                display: flex;
                min-height: 100vh;
            }

            .sidebar {
                width: 220px;
                min-width: 220px;
                background: var(--sidebar-bg);
                border-right: 1px solid var(--card-border);
                display: flex;
                flex-direction: column;
                padding: 1.25rem 0;
                position: fixed;
                height: 100vh;
                z-index: 100;
            }

            .sidebar-brand {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0 1.25rem 1.5rem;
                border-bottom: 1px solid var(--card-border);
                margin-bottom: 1rem;
            }

            .brand-avatar {
                width: 38px;
                height: 38px;
                border-radius: 10px;
                background: linear-gradient(135deg,#4f7cff,#a78bfa);
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1rem;
                color: white;
            }

            .brand-name {
                font-weight: 700;
                font-size: 0.95rem;
                color: var(--text-primary);
            }

            .brand-sub {
                font-size: 0.7rem;
                color: var(--text-secondary);
            }

            .nav-section-label {
                font-size: 0.65rem;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: var(--text-muted);
                padding: 0.75rem 1.25rem 0.4rem;
            }

            .nav-item {
                display: flex;
                align-items: center;
                gap: 0.65rem;
                padding: 0.55rem 1.25rem;
                margin: 0.1rem 0.5rem;
                border-radius: 8px;
                color: var(--text-secondary);
                text-decoration: none;
                font-size: 0.85rem;
                font-weight: 500;
                transition: all 0.18s;
            }

                .nav-item:hover {
                    background: var(--hover-bg);
                    color: var(--text-primary);
                }

                .nav-item.active {
                    background: var(--active-bg);
                    color: var(--accent-blue);
                }

                .nav-item svg {
                    width: 16px;
                    height: 16px;
                    flex-shrink: 0;
                }

            .sidebar-footer {
                margin-top: auto;
                padding: 1rem 1.25rem;
                border-top: 1px solid var(--card-border);
                font-size: 0.78rem;
                color: var(--text-muted);
                display: flex;
                align-items: center;
                gap: 0.5rem;
                cursor: pointer;
            }

            .main {
                margin-left: 220px;
                flex: 1;
                display: flex;
                flex-direction: column;
            }

            .topbar {
                height: 60px;
                background: var(--sidebar-bg);
                border-bottom: 1px solid var(--card-border);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 2rem;
                position: sticky;
                top: 0;
                z-index: 50;
            }

            .search-box {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                border-radius: 8px;
                padding: 0.45rem 0.9rem;
                width: 320px;
            }

                .search-box input {
                    background: none;
                    border: none;
                    outline: none;
                    color: var(--text-primary);
                    font-size: 0.82rem;
                    width: 100%;
                    font-family: inherit;
                }

                    .search-box input::placeholder {
                        color: var(--text-muted);
                    }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .topbar-btn {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                color: var(--text-secondary);
                position: relative;
            }

            .notif-dot {
                width: 7px;
                height: 7px;
                background: var(--accent-red);
                border-radius: 50%;
                position: absolute;
                top: 6px;
                right: 6px;
                border: 1px solid var(--sidebar-bg);
            }

            .user-chip {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                border-radius: 8px;
                padding: 0.35rem 0.75rem;
                cursor: pointer;
            }

            .user-avatar {
                width: 26px;
                height: 26px;
                border-radius: 6px;
                background: linear-gradient(135deg,#4f7cff,#a78bfa);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.7rem;
                font-weight: 700;
                color: white;
            }

            .user-name {
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--text-primary);
            }

            .content {
                padding: 2rem;
                flex: 1;
            }

            .page-header-row {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 1.75rem;
            }

            .page-header h1 {
                font-size: 1.5rem;
                font-weight: 700;
            }

            .page-header p {
                font-size: 0.82rem;
                color: var(--text-secondary);
                margin-top: 0.2rem;
            }

            .btn-primary {
                background: var(--accent-blue);
                color: white;
                border: none;
                padding: 0.5rem 1.1rem;
                border-radius: 8px;
                font-size: 0.82rem;
                font-weight: 600;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 0.4rem;
                transition: all 0.18s;
                font-family: inherit;
            }

                .btn-primary:hover {
                    background: #3a66e8;
                }

            .empresa-grid {
                display: grid;
                grid-template-columns: 1fr 340px;
                gap: 1.5rem;
                align-items: start;
            }

            .card {
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                border-radius: 14px;
                padding: 1.75rem;
                margin-bottom: 1.25rem;
            }

                .card:last-child {
                    margin-bottom: 0;
                }

            .card-title {
                font-size: 0.95rem;
                font-weight: 600;
                margin-bottom: 1.25rem;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                color: var(--text-primary);
            }

                .card-title svg {
                    color: var(--text-muted);
                }

            .logo-upload {
                border: 1.5px dashed var(--card-border);
                border-radius: 10px;
                padding: 1.25rem;
                display: flex;
                align-items: center;
                gap: 1rem;
                margin-bottom: 1.25rem;
                cursor: pointer;
                transition: border-color 0.2s;
            }

                .logo-upload:hover {
                    border-color: var(--accent-blue);
                }

            .logo-placeholder {
                width: 48px;
                height: 48px;
                border-radius: 10px;
                background: linear-gradient(135deg,#4f7cff,#a78bfa);
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

            .logo-info {
                flex: 1;
            }

            .logo-info-title {
                font-size: 0.85rem;
                font-weight: 500;
            }

            .logo-info-sub {
                font-size: 0.73rem;
                color: var(--text-muted);
                margin-top: 0.15rem;
            }

            .upload-btn {
                background: transparent;
                border: 1px solid var(--card-border);
                color: var(--text-secondary);
                padding: 0.35rem 0.8rem;
                border-radius: 7px;
                font-size: 0.75rem;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 0.35rem;
                font-family: inherit;
                transition: all 0.18s;
            }

                .upload-btn:hover {
                    background: var(--hover-bg);
                    color: var(--text-primary);
                }

            .form-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1rem;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: 0.4rem;
            }

                .form-group.full {
                    grid-column: 1/-1;
                }

            .form-label {
                font-size: 0.75rem;
                font-weight: 500;
                color: var(--text-secondary);
            }

            .form-input {
                background: var(--bg);
                border: 1px solid var(--card-border);
                color: var(--text-primary);
                padding: 0.55rem 0.85rem;
                border-radius: 8px;
                font-size: 0.83rem;
                font-family: inherit;
                outline: none;
                transition: border-color 0.18s;
            }

                .form-input:focus {
                    border-color: var(--accent-blue);
                }

            .bottom-grid {
                display: grid;
                grid-template-columns: 1fr 1fr 1fr;
                gap: 1.25rem;
                margin-top: 1.25rem;
            }

            .toggle-row {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0.6rem 0;
            }

            .toggle-info {
            }

            .toggle-label {
                font-size: 0.83rem;
                font-weight: 500;
            }

            .toggle-sub {
                font-size: 0.72rem;
                color: var(--text-muted);
            }

            .toggle {
                width: 42px;
                height: 24px;
                border-radius: 99px;
                background: var(--accent-blue);
                display: flex;
                align-items: center;
                padding: 2px;
                cursor: pointer;
                transition: background 0.2s;
                flex-shrink: 0;
            }

            .toggle-knob {
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: white;
                margin-left: auto;
            }

            .toggle.off {
                background: var(--card-border);
            }

                .toggle.off .toggle-knob {
                    margin-left: 0;
                }
    </style>


<form asp-action="Index"
      method="post"
      enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />

    <div class="main">

        <div class="topbar">
            <div class="search-box">
                <input type="text" placeholder="Buscar..." />
            </div>

            <div class="topbar-right">
                <div class="user-chip">
                    <div class="user-avatar">AD</div>
                    <span class="user-name">Administrador</span>
                </div>
            </div>
        </div>

        <div class="content">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mb-3">
                    @TempData["Success"]
                </div>
            }

            <div class="page-header-row">
                <div class="page-header">
                    <h1>Empresa</h1>
                    <p>Configuración general de CarGoCR</p>
                </div>

                <button type="submit" class="btn-primary">
                    Guardar cambios
                </button>
            </div>

            <div class="empresa-grid">

                <!-- IZQUIERDA -->
                <div>

                    <div class="card">

                        <div class="card-title">
                            Identidad corporativa
                        </div>

                        <div class="logo-upload">

                            @if (!string.IsNullOrEmpty(Model.Logo))
                            {
                                <img src="@Model.Logo"
                                     style="width:90px;height:90px;object-fit:contain;border-radius:10px;" />
                            }
                            else
                            {
                                <div class="logo-placeholder">
                                    LOGO
                                </div>
                            }

                            <div class="logo-info">
                                <div class="logo-info-title">
                                    Logo de la empresa
                                </div>

                                <div class="logo-info-sub">
                                    PNG, JPG o SVG
                                </div>
                            </div>

                            <input type="file"
                                   name="archivoLogo"
                                   class="form-input" />
                        </div>

                        <div class="form-grid">

                            <div class="form-group">
                                <label class="form-label">
                                    Nombre de la empresa
                                </label>

                                <input asp-for="NombreEmpresa"
                                       class="form-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    Razón social
                                </label>

                                <input asp-for="RazonSocial"
                                       class="form-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    Cédula jurídica
                                </label>

                                <input asp-for="CedulaJuridica"
                                       class="form-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    Industria
                                </label>

                                <input asp-for="Industria"
                                       class="form-input" />
                            </div>

                            <div class="form-group full">
                                <label class="form-label">
                                    Descripción
                                </label>

                                <textarea asp-for="Descripcion"
                                          rows="4"
                                          class="form-input"></textarea>
                            </div>

                        </div>

                    </div>

                    <div class="bottom-grid">

                        <!-- REDES -->

                        <div class="card">

                            <div class="card-title">
                                Redes Sociales
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    Instagram
                                </label>

                                <input asp-for="Instagram"
                                       class="form-input" />
                            </div>

                            <br />

                            <div class="form-group">
                                <label class="form-label">
                                    Facebook
                                </label>

                                <input asp-for="Facebook"
                                       class="form-input" />
                            </div>

                            <br />

                            <div class="form-group">
                                <label class="form-label">
                                    Twitter / X
                                </label>

                                <input asp-for="Twitter"
                                       class="form-input" />
                            </div>

                        </div>

                        <!-- MONEDA -->

                        <div class="card">

                            <div class="card-title">
                                Monedas
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    Moneda principal
                                </label>

                                <input asp-for="MonedaPrincipal"
                                       class="form-input" />
                            </div>

                            <br />

                            <div class="form-group">
                                <label class="form-label">
                                    Moneda secundaria
                                </label>

                                <input asp-for="MonedaSecundaria"
                                       class="form-input" />
                            </div>

                            <br />

                            <div class="form-group">
                                <label class="form-label">
                                    Tipo de cambio
                                </label>

                                <input asp-for="TipoCambio"
                                       type="number"
                                       step="0.01"
                                       class="form-input" />
                            </div>

                        </div>

                        <!-- IMPUESTOS -->

                        <div class="card">

                            <div class="card-title">
                                Impuestos
                            </div>

                            <div class="form-group">
                                <label class="form-label">
                                    IVA (%)
                                </label>

                                <input asp-for="IVA"
                                       type="number"
                                       step="0.01"
                                       class="form-input" />
                            </div>

                            <br />

                            <div class="form-check">
                                <input asp-for="IncluirImpuestos"
                                       class="form-check-input" />

                                <label asp-for="IncluirImpuestos"
                                       class="form-check-label">
                                    Incluir impuestos
                                </label>
                            </div>

                            <br />

                            <div class="form-check">
                                <input asp-for="FacturacionElectronica"
                                       class="form-check-input" />

                                <label asp-for="FacturacionElectronica"
                                       class="form-check-label">
                                    Facturación electrónica
                                </label>
                            </div>

                        </div>

                    </div>

                </div>

                <!-- DERECHA -->

                <div class="card">

                    <div class="card-title">
                        Información de contacto
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            Correo electrónico
                        </label>

                        <input asp-for="Correo"
                               class="form-input" />
                    </div>

                    <br />

                    <div class="form-group">
                        <label class="form-label">
                            Teléfono
                        </label>

                        <input asp-for="Telefono"
                               class="form-input" />
                    </div>

                    <br />

                    <div class="form-group">
                        <label class="form-label">
                            Sitio web
                        </label>

                        <input asp-for="SitioWeb"
                               class="form-input" />
                    </div>

                </div>

            </div>

        </div>

    </div>

</form>
