@model CarGoCR.Models.Tarifa

@{
    ViewData["Title"] = "Editar Tarifa";
}

<style>

    body {
        background: #0f1117;
    }

    .page-container {
        padding-top: 40px;
        padding-bottom: 40px;
    }

    .form-card {
        background: #1a1d27;
        border: 1px solid #252836;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,.35);
        color: white;
        backdrop-filter: blur(12px);
    }

    .page-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: .4rem;
        color: #f0f2f8;
    }

    .page-subtitle {
        color: #7b8099;
        margin-bottom: 2rem;
        font-size: .95rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #f0f2f8;
        margin-bottom: 1.2rem;
        padding-bottom: .75rem;
        border-bottom: 1px solid #252836;
    }

    .form-label {
        color: #d7dbea;
        font-weight: 600;
        margin-bottom: .5rem;
    }

    .form-control {
        background: #0f1117;
        border: 1px solid #252836;
        color: #f0f2f8;
        border-radius: 12px;
        padding: 12px 15px;
        transition: all .25s ease;
    }

        .form-control::placeholder {
            color: #4a5068;
        }

        .form-control:focus {
            background: #0f1117;
            color: white;
            border-color: #4f7cff;
            box-shadow: 0 0 0 4px rgba(79,124,255,.15);
        }

    .form-check {
        background: #0f1117;
        border: 1px solid #252836;
        border-radius: 12px;
        padding: 15px;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: #4f7cff;
            border-color: #4f7cff;
        }

    .form-check-label {
        color: #f0f2f8;
        margin-left: .5rem;
        cursor: pointer;
    }

    .text-danger {
        font-size: .85rem;
        margin-top: .3rem;
        display: block;
    }

    .btn-save {
        background: linear-gradient(135deg,#4f7cff,#3b66f0);
        border: none;
        color: white;
        font-weight: 700;
        padding: 12px 24px;
        border-radius: 12px;
        transition: .25s;
        text-decoration: none;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(79,124,255,.30);
            color: white;
        }

    .btn-back {
        background: transparent;
        border: 1px solid #252836;
        color: #d7dbea;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: .25s;
    }

        .btn-back:hover {
            background: #252836;
            color: white;
        }

    .form-divider {
        margin: 2rem 0;
        border-top: 1px solid #252836;
    }

    .layout-content {
        margin-left: 220px;
        width: calc(100% - 220px);
        min-height: 100vh;
        padding: 2rem;
    }

    .action-buttons {
        display: flex;
        gap: 15px;
        margin-top: 40px;
        padding-top: 25px;
        border-top: 1px solid #1e293b;
    }

    .layout-content {
        margin-left: 220px;
        width: calc(100% - 220px);
        min-height: 100vh;
        padding: 2rem;
    }
</style>

<div class="container page-container">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="form-card">

                <h1 class="page-title">
                    Editar Tarifa
                </h1>

                <p class="page-subtitle">
                    Modifica precios y configuraciones de la tarifa
                </p>

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="section-title">
                        Información General
                    </div>

                    <div class="mb-4">

                        <label asp-for="Categoria"
                               class="form-label"></label>

                        <input asp-for="Categoria"
                               class="form-control" />

                        <span asp-validation-for="Categoria"
                              class="text-danger"></span>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label asp-for="PesoMinimo"
                                   class="form-label"></label>

                            <input asp-for="PesoMinimo"
                                   class="form-control" />

                            <span asp-validation-for="PesoMinimo"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label asp-for="PesoMaximo"
                                   class="form-label"></label>

                            <input asp-for="PesoMaximo"
                                   class="form-control" />

                            <span asp-validation-for="PesoMaximo"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <div class="section-title mt-3">
                        Precios
                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label asp-for="PrecioNacional"
                                   class="form-label"></label>

                            <input asp-for="PrecioNacional"
                                   class="form-control" />

                            <span asp-validation-for="PrecioNacional"
                                  class="text-danger"></span>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label asp-for="PrecioInternacional"
                                   class="form-label"></label>

                            <input asp-for="PrecioInternacional"
                                   class="form-control" />

                            <span asp-validation-for="PrecioInternacional"
                                  class="text-danger"></span>

                        </div>

                    </div>

                    <div class="form-check mb-4">

                        <input asp-for="RequiereCotizacion"
                               class="form-check-input" />

                        <label asp-for="RequiereCotizacion"
                               class="form-check-label">

                            Requiere cotización personalizada

                        </label>

                    </div>

                    <div class="form-check mb-5">

                        <input asp-for="Activo"
                               class="form-check-input" />

                        <label asp-for="Activo"
                               class="form-check-label">

                            Tarifa activa

                        </label>

                    </div>

                    <div class="action-buttons">
                        <button type="submit" class="btn-save">
                             Guardar Cambios
                        </button>

                        <a asp-action="Index" class="btn-back">
                            ← Volver
                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}