@model CarGoCR.Models.Tarifa

@{
    ViewData["Title"] = "Detalles de Tarifa";
}

<style>

    body {
        background: #0f1117;
    }

    .details-card {
        background: #1a1d27;
        border: 1px solid #252836;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,.35);
        color: white;
    }

    .page-title {
        font-size: 2rem;
        font-weight: 800;
        color: #f0f2f8;
        margin-bottom: .4rem;
    }

    .page-subtitle {
        color: #7b8099;
        margin-bottom: 2rem;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
        gap: 18px;
    }

    .info-card {
        background: #0f1117;
        border: 1px solid #252836;
        border-radius: 16px;
        padding: 20px;
        transition: .25s;
    }

        .info-card:hover {
            transform: translateY(-3px);
            border-color: #4f7cff;
        }

    .info-label {
        color: #7b8099;
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .5px;
        margin-bottom: 10px;
    }

    .info-value {
        color: #f0f2f8;
        font-size: 1.25rem;
        font-weight: 700;
    }

    .status-active,
    .status-inactive,
    .cotizacion {
        padding: 8px 14px;
        border-radius: 10px;
        font-size: .8rem;
        font-weight: 700;
    }

    .status-active {
        background: rgba(52,211,153,.15);
        color: #34d399;
    }

    .status-inactive {
        background: rgba(248,113,113,.15);
        color: #f87171;
    }

    .cotizacion {
        background: rgba(245,158,11,.15);
        color: #f59e0b;
    }

    .btn-edit {
        background: linear-gradient(135deg,#4f7cff,#3b66f0);
        border: none;
        color: white;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        transition: .25s;
    }

        .btn-edit:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(79,124,255,.3);
        }

    .btn-back {
        background: transparent;
        border: 1px solid #252836;
        color: #d7dbea;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: .25s;
    }

        .btn-back:hover {
            background: #252836;
            color: white;
        }

    .action-buttons {
        margin-top: 40px;
        padding-top: 25px;
        border-top: 1px solid #252836;
        display: flex;
        gap: 12px;
    }
    .layout-content {
        margin-left: 220px;
        width: calc(100% - 220px);
        min-height: 100vh;
        padding: 2rem;
    }
</style>

<div class="container page-container">

    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="details-card">

                <h1 class="page-title">
                    Detalles de Tarifa
                </h1>

                <p class="page-subtitle">
                    Información completa de la tarifa registrada
                </p>

                <div class="info-grid">

                    <div class="info-card">

                        <div class="info-label">
                            Categoría
                        </div>

                        <div class="info-value">
                            @Model.Categoria
                        </div>

                    </div>

                    <div class="info-card">

                        <div class="info-label">
                            Peso mínimo
                        </div>

                        <div class="info-value">
                            @Model.PesoMinimo kg
                        </div>

                    </div>

                    <div class="info-card">

                        <div class="info-label">
                            Peso máximo
                        </div>

                        <div class="info-value">
                            @Model.PesoMaximo kg
                        </div>

                    </div>

                    <div class="info-card">

                        <div class="info-label">
                            Precio nacional
                        </div>

                        <div class="info-value" style="color:#34d399;">
                            $@Model.PrecioNacional
                        </div>

                    </div>

                    <div class="info-card">

                        <div class="info-label">
                            Precio internacional
                        </div>

                        <div class="info-value" style="color:#4f7cff;">
                            $@Model.PrecioInternacional
                        </div>

                    </div>

                    <div class="info-card">

                        <div class="info-label">
                            Cotización personalizada
                        </div>

                        <div class="info-value">

                            @if (Model.RequiereCotizacion)
                            {
                                <span class="cotizacion">
                                    Requiere cotización
                                </span>
                            }
                            else
                            {
                                <span>
                                    No requerida
                                </span>
                            }

                        </div>

                    </div>

                    <div class="info-card">

                        <div class="info-label">
                            Estado
                        </div>

                        <div class="info-value">

                            @if (Model.Activo)
                            {
                                <span class="status-active">
                                    Activa
                                </span>
                            }
                            else
                            {
                                <span class="status-inactive">
                                    Inactiva
                                </span>
                            }

                        </div>

                    </div>

                </div>
                <div class="action-buttons">

                    <a asp-action="Edit"
                       asp-route-id="@Model.Id"
                       class="btn-edit">
                         Editar Tarifa
                    </a>

                    <a asp-action="Index"
                       class="btn-back">
                        ← Volver
                    </a>

                </div>
            </div>

        </div>

    </div>

</div>