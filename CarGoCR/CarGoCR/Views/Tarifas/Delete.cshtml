@model CarGoCR.Models.Tarifa

@{
    ViewData["Title"] = "Eliminar Tarifa";
}

<style>

    body {
        background: #020817;
    }

    .page-container {
        padding-top: 40px;
        padding-bottom: 40px;
    }

    .delete-card {
        background: #071226;
        border: 1px solid #7f1d1d;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.35);
        color: white;
    }

    .warning-icon {
        width: 90px;
        height: 90px;
        background: rgba(220,38,38,0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: auto;
        margin-bottom: 25px;
        color: #ef4444;
    }

    .page-title {
        text-align: center;
        font-weight: 800;
        margin-bottom: 10px;
        color: white;
    }

    .page-subtitle {
        text-align: center;
        color: #94a3b8;
        margin-bottom: 40px;
    }

    .info-box {
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 18px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #1e293b;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: #94a3b8;
        font-weight: 600;
    }

    .info-value {
        color: white;
        font-weight: 700;
    }

    .status-active {
        background: #16a34a;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .status-inactive {
        background: #dc2626;
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .btn-delete {
        background: linear-gradient(135deg, #dc2626, #991b1b);
        border: none;
        color: white;
        font-weight: 700;
        padding: 12px 26px;
        border-radius: 14px;
        transition: 0.3s;
    }

        .btn-delete:hover {
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            color: white;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: #1e293b;
        color: white;
        padding: 12px 26px;
        border-radius: 14px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-cancel:hover {
            background: #334155;
            color: white;
        }

</style>

<div class="container page-container">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="delete-card">

                <div class="warning-icon">
                    ⚠
                </div>

                <h1 class="page-title">
                    Eliminar Tarifa
                </h1>

                <p class="page-subtitle">
                    Esta acción eliminará permanentemente la tarifa seleccionada
                </p>

                <div class="info-box">

                    <div class="info-row">

                        <span class="info-label">
                            Categoría
                        </span>

                        <span class="info-value">
                            @Model.Categoria
                        </span>

                    </div>

                    <div class="info-row">

                        <span class="info-label">
                            Rango de peso
                        </span>

                        <span class="info-value">
                            @Model.PesoMinimo kg - @Model.PesoMaximo kg
                        </span>

                    </div>

                    <div class="info-row">

                        <span class="info-label">
                            Precio nacional
                        </span>

                        <span class="info-value">
                            $@Model.PrecioNacional
                        </span>

                    </div>

                    <div class="info-row">

                        <span class="info-label">
                            Precio internacional
                        </span>

                        <span class="info-value">
                            $@Model.PrecioInternacional
                        </span>

                    </div>

                    <div class="info-row">

                        <span class="info-label">
                            Estado
                        </span>

                        <span class="info-value">

                            @if (Model.Activo)
                            {
                                <span class="status-active">
                                    Activa
                                </span>
                            }
                            else
                            {
                                <span class="status-inactive">
                                    Inactiva
                                </span>
                            }

                        </span>

                    </div>

                </div>

                <form asp-action="Delete" method="post">

                    <input type="hidden" asp-for="Id" />

                    <div class="d-flex justify-content-center gap-3 mt-4">

                        <button type="submit"
                                class="btn-delete">

                            Eliminar Tarifa

                        </button>

                        <a asp-action="Index"
                           class="btn-cancel">

                            Cancelar

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>