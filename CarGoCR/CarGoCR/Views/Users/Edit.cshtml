@model CarGoCR.Models.ApplicationUser

@{
    ViewData["Title"] = "Editar Usuario";
}

<style>
    .layout-content {
        margin-left: 220px;
        width: calc(100% - 220px);
        min-height: 100vh;
        padding: 2rem;
    }

    .form-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 14px;
        padding: 2rem;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    .form-label {
        margin-bottom: .4rem;
        color: var(--text-secondary);
        font-size: .85rem;
    }

    .form-input {
        background: var(--bg);
        border: 1px solid var(--card-border);
        color: var(--text-primary);
        padding: .75rem;
        border-radius: 8px;
    }

    .form-actions {
        margin-top: 1.5rem;
        display: flex;
        gap: .75rem;
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-top: 1.5rem;
    }
</style>

<div class="content">

    <div class="page-header-row">
        <div class="page-header">
            <h1>Editar Usuario</h1>
            <p>Actualizar información del usuario</p>
        </div>

        <a asp-action="Index"
           class="btn-primary"
           style="text-decoration:none;">
            Volver
        </a>
    </div>

    <div class="form-card">

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="NombreCompleto"
                           class="form-label">
                        Nombre Completo
                    </label>

                    <input asp-for="NombreCompleto"
                           class="form-input" />
                </div>

                <div class="form-group">
                    <label asp-for="UserName"
                           class="form-label">
                        Usuario
                    </label>

                    <input asp-for="UserName"
                           class="form-input" />
                </div>

                <div class="form-group">
                    <label asp-for="Email"
                           class="form-label">
                        Correo
                    </label>

                    <input asp-for="Email"
                           class="form-input" />
                </div>

                <div class="form-group">
                    <label asp-for="PhoneNumber"
                           class="form-label">
                        Teléfono
                    </label>

                    <input asp-for="PhoneNumber"
                           class="form-input" />
                </div>

            </div>

            <div class="checkbox-group">

                <input asp-for="Activo" />

                <label asp-for="Activo">
                    Usuario activo
                </label>

            </div>

            <div class="form-actions">

                <button type="submit"
                        class="btn-primary">
                    Guardar cambios
                </button>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}