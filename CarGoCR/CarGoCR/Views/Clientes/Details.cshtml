@model CarGoCR.Models.Cliente

@{
    ViewData["Title"] = "Detalles del Cliente";
}
<style>
    .info-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 1rem;
    }

    .info-item {
        background: var(--bg);
        border: 1px solid var(--card-border);
        border-radius: 10px;
        padding: 1rem;
    }

        .info-item span {
            display: block;
            color: var(--text-secondary);
            font-size: .8rem;
            margin-bottom: .4rem;
        }

        .info-item strong {
            color: var(--text-primary);
        }

    .action-buttons {
        margin-top: 2rem;
        display: flex;
        gap: .75rem;
    }

    .badge-active {
        background: rgba(52,211,153,.15);
        color: var(--accent-green);
        padding: .35rem .8rem;
        border-radius: 8px;
        font-size: .8rem;
        font-weight: 600;
    }

    .badge-inactive {
        background: rgba(248,113,113,.15);
        color: var(--accent-red);
        padding: .35rem .8rem;
        border-radius: 8px;
        font-size: .8rem;
        font-weight: 600;
    }

    .action-buttons {
        margin-top: 2rem;
        display: flex;
        gap: .75rem;
    }

    /* Botón Editar */
    .btn-edit {
        background: var(--accent-blue);
        color: #fff;
        padding: .85rem 1.4rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        border: none;
        transition: .25s;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
    }

        .btn-edit:hover {
            background: #3a66e8;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(79,124,255,.25);
        }

    /* Botón Volver / Cancelar */
    .btn-secondary-modern {
        background: transparent;
        border: 1px solid var(--card-border);
        color: var(--text-primary);
        padding: .85rem 1.4rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        transition: .25s;
        display: inline-flex;
        align-items: center;
    }

        .btn-secondary-modern:hover {
            background: var(--hover-bg);
            border-color: var(--accent-blue);
        }

    /* Botón Eliminar */
    .btn-delete {
        background: var(--accent-red);
        color: white;
        border: none;
        padding: .85rem 1.4rem;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: .25s;
    }

        .btn-delete:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(248,113,113,.25);
        }

    .layout-content {
        margin-left: 220px;
        width: calc(100% - 220px);
        min-height: 100vh;
        padding: 2rem;
    }

</style>
<div class="page-card">

    <h1 class="page-title">Detalles del Cliente</h1>

    <p class="page-subtitle">
        Información completa del cliente registrado.
    </p>

    <div class="info-grid">

        <div class="info-item">
            <span>ID</span>
            <strong>@Model.Id</strong>
        </div>

        <div class="info-item">
            <span>Nombre Completo</span>
            <strong>@Model.NombreCompleto</strong>
        </div>

        <div class="info-item">
            <span>Correo</span>
            <strong>@Model.Correo</strong>
        </div>

        <div class="info-item">
            <span>Teléfono</span>
            <strong>@Model.Telefono</strong>
        </div>

        <div class="info-item">
            <span>Cédula</span>
            <strong>@Model.Cedula</strong>
        </div>

        <div class="info-item">
            <span>Dirección</span>
            <strong>@Model.Direccion</strong>
        </div>

        <div class="info-item">
            <span>Estado</span>

            @if (Model.Activo)
            {
                <span class="badge-active">Activo</span>
            }
            else
            {
                <span class="badge-inactive">Inactivo</span>
            }

        </div>

        <div class="info-item">
            <span>Fecha Registro</span>
            <strong>@Model.FechaRegistro.ToShortDateString()</strong>
        </div>

    </div>

    <div class="action-buttons">

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn-edit">
                 Editar Cliente
            </a>

            <a asp-action="Index"
               class="btn-secondary-modern">
                ← Volver
            </a>

    </div>

</div>