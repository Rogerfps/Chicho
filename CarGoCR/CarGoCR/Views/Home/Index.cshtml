@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">
    <!-- Encabezdo principal -->
    <div class="text-center">
        <img src="~/img/Logo.jpeg"
             alt="CarGoCR Logo"
             class="img-fluid mb-4"
             style="max-width: 220px; border-radius: 20px; box-shadow: 0 8px 20px rgba(0,0,0,0.1);" />

        <h1 class="display-4 fw-bold" style="color: #1e3a8a;">
            Sistema CarGoCR
        </h1>

        <p class="lead" style="color: #b91c1c;">
            Plataforma de gestión de paquetes y clientes
        </p>
    </div>

    <!-- Tarjetas de módulos con estilos azul/rojo -->
    <div class="row justify-content-center mt-5 g-4">

        <!-- Módulo Clientes (Azul) -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 h-100"
                 style="border-top: 5px solid #2563eb;">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-people-fill" style="font-size: 3rem; color: #2563eb;"></i>
                    </div>
                    <h3 class="mb-3" style="color: #1e3a8a;">Clientes</h3>
                    <p class="text-muted">Administración completa de clientes registrados.</p>
                    <a asp-controller="Clientes"
                       asp-action="Index"
                       class="btn w-100"
                       style="background-color: #2563eb; color: white; border-radius: 50px;">
                        Ir al Módulo
                    </a>
                </div>
            </div>
        </div>

        <!-- Módulo Paquetes (Rojo) -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 h-100"
                 style="border-top: 5px solid #dc2626;">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-box-seam-fill" style="font-size: 3rem; color: #dc2626;"></i>
                    </div>
                    <h3 class="mb-3" style="color: #991b1b;">Paquetes</h3>
                    <p class="text-muted">Gestión de envíos, rastreo y estados.</p>
                    <a asp-controller="Paquetes"
                       asp-action="Index"
                       class="btn w-100"
                       style="background-color: #dc2626; color: white; border-radius: 50px;">
                        Ir al Módulo
                    </a>
                </div>
            </div>
        </div>

        <!-- Módulo Reportes (Combinación azul/rojo) -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 h-100"
                 style="border-top: 5px solid #8b5cf6;">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-graph-up" style="font-size: 3rem; color: #8b5cf6;"></i>
                    </div>
                    <h3 class="mb-3" style="color: #4c1d95;">Reportes</h3>
                    <p class="text-muted">Estadísticas y análisis de operaciones.</p>
                    <a asp-controller="Reportes"
                       asp-action="Index"
                       class="btn w-100"
                       style="background: linear-gradient(135deg, #2563eb, #dc2626); color: white; border-radius: 50px;">
                        Ver Reportes
                    </a>
                </div>
            </div>
        </div>

        <!-- Módulo Reportes (Combinación azul/rojo) -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0 rounded-4 h-100"
                 style="border-top: 5px solid #8b5cf6;">
                <div class="card-body text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-graph-up" style="font-size: 3rem; color: #8b5cf6;"></i>
                    </div>
                    <h3 class="mb-3" style="color: #4c1d95;">Reportes</h3>
                    <p class="text-muted">Estadísticas y análisis de operaciones.</p>
                    <a asp-controller="Tarifas"
                       asp-action="Index"
                       class="btn w-100"
                       style="background: linear-gradient(135deg, #2563eb, #dc2626); color: white; border-radius: 50px;">
                        Ver Reportes
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección adicional con estadísticas rápidas (opcional) -->
    <div class="row mt-5 text-center">
        <div class="col-md-4">
            <div class="p-3 rounded-3" style="background-color: #eff6ff;">
                <h2 style="color: #1e3a8a;">+150</h2>
                <p style="color: #b91c1c;">Clientes activos</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded-3" style="background-color: #fef2f2;">
                <h2 style="color: #991b1b;">+320</h2>
                <p style="color: #1e3a8a;">Paquetes enviados</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 rounded-3" style="background: linear-gradient(145deg, #eff6ff, #fef2f2);">
                <h2 style="color: #4c1d95;">98%</h2>
                <p style="color: #b91c1c;">Satisfacción</p>
            </div>
        </div>
    </div>
</div>

