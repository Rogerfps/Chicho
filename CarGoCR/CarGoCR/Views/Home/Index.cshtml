<!-- MAIN -->
<div class="main">
    <!-- TOPBAR -->
    <div class="topbar">
        <div class="search-box">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--text-muted)"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input type="text" placeholder="Buscar clientes, paquetes, facturas...">
        </div>
        <div class="topbar-right">
            <div class="topbar-btn">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 0 1-3.46 0" /></svg>
                <span class="notif-dot"></span>
            </div>
            <div class="topbar-btn">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93A10 10 0 1 0 4.93 19.07 10 10 0 0 0 19.07 4.93z" /></svg>
            </div>
            <div class="user-chip">
                <div class="user-avatar">AP</div>
                <span class="user-name">Admin</span>
            </div>
        </div>
    </div>

    <!-- CONTENT -->
    <div class="content">
        <div class="page-header-row">
            <div class="page-header">
                <h1>Dashboard</h1>
                <p>Resumen general del rendimiento de tu negocio</p>
            </div>
            <div style="display:flex;gap:0.75rem;margin-top:0.25rem">
                <button class="btn-outline">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Exportar
                </button>
                <button class="btn-primary">Generar reporte</button>
            </div>
        </div>

        <!-- STATS -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon blue"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg></div>
                    <span class="stat-badge up">↑ +12.5%</span>
                </div>
                <div class="stat-value">$48,250</div>
                <div class="stat-label">Ingresos del mes</div>
            </div>
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon green"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1" /><circle cx="20" cy="21" r="1" /><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" /></svg></div>
                    <span class="stat-badge up">↑ +8.2%</span>
                </div>
                <div class="stat-value">1,284</div>
                <div class="stat-label">Ventas</div>
            </div>
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon purple"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg></div>
                    <span class="stat-badge up">↑ +4.1%</span>
                </div>
                <div class="stat-value">892</div>
                <div class="stat-label">Clientes activos</div>
            </div>
            <div class="stat-card">
                <div class="stat-top">
                    <div class="stat-icon orange"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /></svg></div>
                    <span class="stat-badge down">↓ -2.4%</span>
                </div>
                <div class="stat-value">147</div>
                <div class="stat-label">Paquetes en tránsito</div>
            </div>
        </div>

        <!-- CHARTS -->
        <div class="charts-row">
            <div class="chart-card">
                <div class="chart-header">
                    <div>
                        <div class="chart-title">Ingresos y ventas</div>
                        <div class="chart-sub">Últimos 12 meses</div>
                    </div>
                    <span class="chart-badge">↑ +24.8%</span>
                </div>
                <div class="chart-wrap"><canvas id="lineChart"></canvas></div>
            </div>
            <div class="chart-card">
                <div class="chart-header">
                    <div>
                        <div class="chart-title">Por categoría</div>
                        <div class="chart-sub">Distribución de ventas</div>
                    </div>
                </div>
                <div class="donut-wrap"><canvas id="donutChart"></canvas></div>
                <div class="legend">
                    <div class="legend-item"><div class="legend-dot-label"><div class="legend-dot" style="background:#4f7cff"></div>Electrónica</div><span class="legend-pct">35%</span></div>
                    <div class="legend-item"><div class="legend-dot-label"><div class="legend-dot" style="background:#fb923c"></div>Ropa</div><span class="legend-pct">25%</span></div>
                    <div class="legend-item"><div class="legend-dot-label"><div class="legend-dot" style="background:#34d399"></div>Hogar</div><span class="legend-pct">20%</span></div>
                    <div class="legend-item"><div class="legend-dot-label"><div class="legend-dot" style="background:#fbbf24"></div>Otros</div><span class="legend-pct">20%</span></div>
                </div>
            </div>
        </div>

        <!-- BOTTOM ROW -->
        <div class="bottom-row">
            <div class="table-card">
                <div class="chart-header">
                    <div>
                        <div class="chart-title">Actividad reciente</div>
                    </div>
                </div>
                <table class="data-table">
                    <thead><tr><th>Producto</th><th>Vendidos</th><th>Ingresos</th><th>Tendencia</th></tr></thead>
                    <tbody>
                        <tr><td>Envío express USA-CR</td><td>482</td><td>$21,690</td><td><span class="trend-up">↑ +10%</span></td></tr>
                        <tr><td>Paquete estándar</td><td>367</td><td>$11,010</td><td><span class="trend-up">↑ +12%</span></td></tr>
                        <tr><td>Carga pesada</td><td>124</td><td>$9,920</td><td><span class="trend-up">↑ +5%</span></td></tr>
                        <tr><td>Documentos</td><td>311</td><td>$5,630</td><td><span class="trend-down">↓ -2%</span></td></tr>
                    </tbody>
                </table>
            </div>
            <div class="chart-card">
                <div class="chart-header">
                    <div class="chart-title">Ventas semanales</div>
                </div>
                <div class="weekly-list">
                    <div class="weekly-item"><span class="weekly-day">Lun</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:70%"></div></div><span class="weekly-val">$3,420</span></div>
                    <div class="weekly-item"><span class="weekly-day">Mar</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:55%"></div></div><span class="weekly-val">$2,680</span></div>
                    <div class="weekly-item"><span class="weekly-day">Mié</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:85%"></div></div><span class="weekly-val">$4,150</span></div>
                    <div class="weekly-item"><span class="weekly-day">Jue</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:60%"></div></div><span class="weekly-val">$2,940</span></div>
                    <div class="weekly-item"><span class="weekly-day">Vie</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:95%"></div></div><span class="weekly-val">$5,120</span></div>
                    <div class="weekly-item"><span class="weekly-day">Sáb</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:45%"></div></div><span class="weekly-val">$2,190</span></div>
                    <div class="weekly-item"><span class="weekly-day">Dom</span><div class="weekly-bar-bg"><div class="weekly-bar" style="width:30%"></div></div><span class="weekly-val">$1,450</span></div>
                </div>
            </div>
        </div>
    </div>
</div>

    
    <script>
            const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
            const ctx1 = document.getElementById('lineChart').getContext('2d');
            const gradient1 = ctx1.createLinearGradient(0,0,0,220);
            gradient1.addColorStop(0,'rgba(79,124,255,0.3)');
            gradient1.addColorStop(1,'rgba(79,124,255,0)');
            const gradient2 = ctx1.createLinearGradient(0,0,0,220);
            gradient2.addColorStop(0,'rgba(167,139,250,0.2)');
            gradient2.addColorStop(1,'rgba(167,139,250,0)');
            new Chart(ctx1,{
              type:'line',
              data:{
                labels:months,
                datasets:[
                  {label:'Ingresos',data:[3200,3800,4100,4600,5200,5800,6400,7100,8200,10200,11500,13800],
                    borderColor:'#4f7cff',backgroundColor:gradient1,borderWidth:2,pointBackgroundColor:'#4f7cff',
                    pointRadius:3,tension:0.4,fill:true},
                  {label:'Ventas',data:[2800,3200,3600,3900,4400,4900,5500,6100,7000,8800,9800,11500],
                    borderColor:'#a78bfa',backgroundColor:gradient2,borderWidth:2,pointBackgroundColor:'#a78bfa',
                    pointRadius:3,tension:0.4,fill:true}
                ]
              },
              options:{
                responsive:true,maintainAspectRatio:false,
                plugins:{legend:{display:false}},
                scales:{
                  x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#7b8099',font:{size:11}}},
                  y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#7b8099',font:{size:11}},min:0}
                }
              }
            });

            const ctx2 = document.getElementById('donutChart').getContext('2d');
            new Chart(ctx2,{
              type:'doughnut',
              data:{
                datasets:[{data:[35,25,20,20],
                  backgroundColor:['#4f7cff','#fb923c','#34d399','#fbbf24'],
                  borderWidth:0,hoverOffset:4}]
              },
              options:{
                responsive:true,maintainAspectRatio:false,
                plugins:{legend:{display:false}},
                cutout:'68%'
              }
            });
    </script>
