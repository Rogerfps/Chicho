    </div>
    <script>
        const ctx = document.getElementById('ventas-chart').getContext('2d');
        const g = ctx.createLinearGradient(0,0,0,240);
        g.addColorStop(0,'rgba(79,124,255,0.3)');
        g.addColorStop(1,'rgba(79,124,255,0)');
        new Chart(ctx,{type:'line',data:{labels:['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],datasets:[{data:[3200,3800,4100,4400,5100,5600,6300,7200,8000,10200,11800,13500],borderColor:'#4f7cff',backgroundColor:g,borderWidth:2.5,pointBackgroundColor:'#4f7cff',pointRadius:4,tension:0.4,fill:true}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>`ventas: ${ctx.parsed.y}`}}},scales:{x:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#7b8099',font:{size:11}}},y:{grid:{color:'rgba(255,255,255,0.04)'},ticks:{color:'#7b8099',font:{size:11}},min:0}}}});
    </script>
