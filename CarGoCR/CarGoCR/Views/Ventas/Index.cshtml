                        <div class="bar-item"><div class="bar-item-label"><span class="bar-item-name">Electrónica</span><span class="bar-item-val">35%</span></div><div class="bar-bg"><div class="bar-fill" style="width:100%;background:var(--accent-blue)"></div></div></div>
